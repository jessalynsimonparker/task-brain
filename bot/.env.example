# Copy this file to .env and fill in your values
# NEVER commit .env to git

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Bot token — starts with xoxb-
SLACK_BOT_TOKEN=xoxb-your-bot-token

# App-level token — starts with xapp- (required for Socket Mode)
# Generate this in your Slack app settings under "Basic Information > App-Level Tokens"
SLACK_APP_TOKEN=xapp-your-app-token

# The channel ID for #jess-reminders (not the name — the ID like C0XXXXXXXXX)
SLACK_CHANNEL_ID=C0XXXXXXXXX

ANTHROPIC_API_KEY=sk-ant-your-key-here

# Port is set automatically by Railway — leave this as-is
PORT=3000
